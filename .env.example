# ClipMaster Pro v1.1
# Local Docker (recommended)
DATABASE_URL="postgresql://clipmaster:clipmaster@localhost:5432/clipmaster"
# Local SQLite fallback:
# DATABASE_URL="file:./dev.db"
# then: npx prisma db push --schema=prisma/schema.sqlite.prisma

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="clipmaster-pro-super-secret-change-this-123456"

# Social API (optional – leave empty for demo stub)
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
IG_APP_ID=""
IG_APP_SECRET=""

# Storage / Export
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="clipmaster"
S3_SECRET_KEY="clipmaster123"
S3_BUCKET="clipmaster-renders"

# Redis / Queue
REDIS_URL="redis://localhost:6379"
