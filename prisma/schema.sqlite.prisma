// Local SQLite fallback – copy of v1.1 but provider sqlite + no @db.Text
// Use: npx prisma db push --schema=prisma/schema.sqlite.prisma
// then: DATABASE_URL="file:./dev.db" npx prisma generate --schema=prisma/schema.sqlite.prisma

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

