{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "regions": ["sin1"],
  "env": {
    "NEXTAUTH_URL": "@nextauth_url",
    "NEXTAUTH_SECRET": "@nextauth_secret",
    "DATABASE_URL": "@database_url"
  },
  "functions": {
    "src/app/api/export/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/post/route.ts": {
      "maxDuration": 30
    }
  }
}
